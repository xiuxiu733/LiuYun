<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="LiuYun.Views.SettingsPage"
    NavigationCacheMode="Required"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <Page.Resources>
        <Style x:Key="SettingsCardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource LiuYunSettingsCardBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="14"/>
        </Style>

        <Style x:Key="SettingsCompactCardBorderStyle"
               TargetType="Border"
               BasedOn="{StaticResource SettingsCardBorderStyle}">
            <Setter Property="Padding" Value="12,6"/>
        </Style>

        <Style x:Key="SettingsTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="NoHoverButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          ContentTransitions="{TemplateBinding ContentTransitions}"
                                          CornerRadius="{TemplateBinding CornerRadius}"
                                          HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Padding="{TemplateBinding Padding}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionHeaderButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource NoHoverButtonStyle}">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="MinHeight" Value="22"/>
        </Style>

        <Style x:Key="SectionChevronIconStyle" TargetType="FontIcon">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="SectionHeaderTitleStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource SettingsTitleStyle}">
            <Setter Property="FontSize" Value="14"/>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Padding="12" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Spacing="8">
                <TextBlock Text="设置"
                           FontSize="20"
                           FontWeight="SemiBold"/>
            </StackPanel>

            <Button Grid.Column="1"
                    Height="32"
                    Padding="10,0"
                    VerticalAlignment="Top"
                    Click="BackToClipboardButton_Click">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE72B;" FontSize="12"/>
                    <TextBlock Text="返回剪切板"/>
                </StackPanel>
            </Button>
        </Grid>

        <ScrollViewer Grid.Row="1"
                      Padding="12,0,4,12"
                      VerticalScrollBarVisibility="Hidden"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollMode="Enabled"
                      HorizontalScrollMode="Disabled">
            <Grid Margin="0,0,8,0" RowSpacing="14" ColumnSpacing="14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Row="0" Grid.Column="0"
                        VerticalAlignment="Top"
                        Style="{StaticResource SettingsCompactCardBorderStyle}">
                    <Grid RowSpacing="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Button Grid.Row="0"
                                Style="{StaticResource SectionHeaderButtonStyle}"
                                Click="SectionToggleButton_Click"
                                Tag="StartupSectionContent|StartupSectionChevron">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Style="{StaticResource SectionHeaderTitleStyle}"
                                           Text="开机自启动"
                                           VerticalAlignment="Center"/>
                                <FontIcon Grid.Column="1"
                                          x:Name="StartupSectionChevron"
                                          Glyph="&#xE70D;"
                                          Style="{StaticResource SectionChevronIconStyle}"/>
                            </Grid>
                        </Button>

                        <Grid Grid.Row="1"
                              x:Name="StartupSectionContent"
                              Visibility="Collapsed"
                              Margin="0,6,0,0"
                              RowSpacing="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       x:Name="StartupStatusText"
                                       Text="正在检查启动状态..."
                                       FontSize="11"
                                       MaxLines="3"
                                       TextWrapping="Wrap"
                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                       VerticalAlignment="Center"/>

                            <Button Grid.Row="1"
                                    x:Name="StartupToggleButton"
                                    Content="开启自启动"
                                    Click="StartupToggleButton_Click"
                                    HorizontalAlignment="Stretch"
                                    Padding="0,6"/>
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2"
                        Style="{StaticResource SettingsCompactCardBorderStyle}">
                    <Grid RowSpacing="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Button Grid.Row="0"
                                Style="{StaticResource SectionHeaderButtonStyle}"
                                Click="SectionToggleButton_Click"
                                Tag="HotkeySectionContent|HotkeySectionChevron">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Style="{StaticResource SectionHeaderTitleStyle}"
                                           Text="全局热键"
                                           VerticalAlignment="Center"/>
                                <FontIcon Grid.Column="1"
                                          x:Name="HotkeySectionChevron"
                                          Glyph="&#xE70D;"
                                          Style="{StaticResource SectionChevronIconStyle}"/>
                            </Grid>
                        </Button>

                        <Grid Grid.Row="1"
                              x:Name="HotkeySectionContent"
                              Visibility="Collapsed"
                              Margin="0,6,0,0"
                              RowSpacing="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0"
                                  ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.2*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0"
                                            Spacing="5"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="系统热键默认仅支持 win + v；普通快捷键支持双击（如 ctrl + ctrl）或二键/三键组合（如 ctrl + l、ctrl + shift + l）。"
                                               FontSize="11"
                                               TextWrapping="Wrap"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock x:Name="HotkeyGuideText"
                                               Text="点击右侧组合键区域开始录入，下方清除按钮可取消。"
                                               FontSize="11"
                                               TextWrapping="Wrap"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>

                                <Border Grid.Column="1"
                                        Width="1"
                                        Margin="2,0"
                                        Background="{ThemeResource TextFillColorSecondaryBrush}"
                                        Opacity="0.28"/>

                                <StackPanel Grid.Column="2"
                                            Spacing="6"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="组合键 / 当前按键"
                                               FontSize="11"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                                    <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8">
                                        <Button x:Name="HotkeyCaptureButton"
                                                Height="34"
                                                Click="HotkeyCaptureButton_Click"
                                                Style="{StaticResource NoHoverButtonStyle}"
                                                HorizontalContentAlignment="Left"
                                                VerticalContentAlignment="Center"
                                                Padding="10,0"
                                                CornerRadius="8">
                                            <TextBlock x:Name="HotkeyCaptureText"
                                                       Text="点击设置快捷键"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                                       TextTrimming="CharacterEllipsis"
                                                       MaxLines="1"/>
                                        </Button>
                                    </Border>

                                    <Button x:Name="ClearHotkeyButton"
                                            Content="清除"
                                            Click="ClearHotkeyButton_Click"
                                            HorizontalAlignment="Stretch"
                                            Padding="0,6"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock x:Name="ClipboardStatusText"
                                       Text=""
                                       Visibility="Collapsed"
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Row="0" Grid.Column="1"
                        VerticalAlignment="Top"
                        Style="{StaticResource SettingsCompactCardBorderStyle}">
                    <Grid RowSpacing="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Button Grid.Row="0"
                                Style="{StaticResource SectionHeaderButtonStyle}"
                                Click="SectionToggleButton_Click"
                                Tag="ExitSectionContent|ExitSectionChevron">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Style="{StaticResource SectionHeaderTitleStyle}"
                                           Text="退出应用"
                                           VerticalAlignment="Center"/>
                                <FontIcon Grid.Column="1"
                                          x:Name="ExitSectionChevron"
                                          Glyph="&#xE70D;"
                                          Style="{StaticResource SectionChevronIconStyle}"/>
                            </Grid>
                        </Button>

                        <Grid Grid.Row="1"
                              x:Name="ExitSectionContent"
                              Visibility="Collapsed"
                              Margin="0,6,0,0"
                              RowSpacing="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Text="完全关闭 LiuYun（包括托盘图标）。"
                                       FontSize="11"
                                       MaxLines="3"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Center"
                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>

                            <Button Grid.Row="1"
                                    Content="退出应用"
                                    Click="ExitButton_Click"
                                    HorizontalAlignment="Stretch"
                                    Padding="0,6"/>
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                        Style="{StaticResource SettingsCompactCardBorderStyle}">
                    <Grid RowSpacing="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Button Grid.Row="0"
                                Style="{StaticResource SectionHeaderButtonStyle}"
                                Click="SectionToggleButton_Click"
                                Tag="PopupPlacementSectionContent|PopupPlacementSectionChevron">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Style="{StaticResource SectionHeaderTitleStyle}"
                                           Text="弹窗方式"
                                           VerticalAlignment="Center"/>
                                <FontIcon Grid.Column="1"
                                          x:Name="PopupPlacementSectionChevron"
                                          Glyph="&#xE70D;"
                                          Style="{StaticResource SectionChevronIconStyle}"/>
                            </Grid>
                        </Button>

                        <Grid Grid.Row="1"
                              x:Name="PopupPlacementSectionContent"
                              Visibility="Collapsed"
                              Margin="0,6,0,0"
                              RowSpacing="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Text="选择剪切板弹窗出现方式。"
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Center"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                            <StackPanel Grid.Row="1"
                                        Spacing="8">
                                <StackPanel Spacing="2">
                                    <RadioButton x:Name="FollowMousePlacementRadioButton"
                                                 GroupName="PopupPlacementMode"
                                                 Content="跟随鼠标位置"
                                                 FontSize="12"
                                                 Checked="PopupPlacementRadioButton_Checked"/>
                                    <TextBlock Text="每次唤出时优先在当前鼠标附近显示。"
                                               Margin="24,0,0,0"
                                               FontSize="10"
                                               TextWrapping="Wrap"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>

                                <StackPanel Spacing="2">
                                    <RadioButton x:Name="FreeDragPlacementRadioButton"
                                                 GroupName="PopupPlacementMode"
                                                 Content="自由拖动"
                                                 FontSize="12"
                                                 Checked="PopupPlacementRadioButton_Checked"/>
                                    <TextBlock Text="按住窗口边缘空白区域拖动，位置会被记住并用于下次弹出。"
                                               Margin="24,0,0,0"
                                               FontSize="10"
                                               TextWrapping="Wrap"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>
                            </StackPanel>

                            <TextBlock Grid.Row="2"
                                       x:Name="PopupPlacementStatusText"
                                       Text="当前方式：跟随鼠标位置。"
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                        Style="{StaticResource SettingsCompactCardBorderStyle}">
                    <Grid RowSpacing="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Button Grid.Row="0"
                                Style="{StaticResource SectionHeaderButtonStyle}"
                                Click="SectionToggleButton_Click"
                                Tag="DataStorageSectionContent|DataStorageSectionChevron">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Style="{StaticResource SectionHeaderTitleStyle}"
                                           Text="数据存储位置迁移"
                                           VerticalAlignment="Center"/>
                                <FontIcon Grid.Column="1"
                                          x:Name="DataStorageSectionChevron"
                                          Glyph="&#xE70D;"
                                          Style="{StaticResource SectionChevronIconStyle}"/>
                            </Grid>
                        </Button>

                        <Grid Grid.Row="1"
                              x:Name="DataStorageSectionContent"
                              Visibility="Collapsed"
                              Margin="0,6,0,0"
                              RowSpacing="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       x:Name="DataStoragePathText"
                                       Text="当前路径：加载中..."
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                            <Grid Grid.Row="1" ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Button Grid.Column="0"
                                        Content="更改存储位置"
                                        Click="ChangeDataStoragePathButton_Click"
                                        HorizontalAlignment="Stretch"
                                        Padding="0,6"/>

                                <Button Grid.Column="1"
                                        Content="打开当前目录"
                                        Click="OpenDataStorageFolderButton_Click"
                                        HorizontalAlignment="Stretch"
                                        Padding="0,6"/>
                            </Grid>

                            <TextBlock Grid.Row="2"
                                       x:Name="DataStorageStatusText"
                                       Text="提示：迁移将在重启应用后执行，旧目录不会自动删除。"
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                        Style="{StaticResource SettingsCompactCardBorderStyle}">
                    <Grid RowSpacing="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Button Grid.Row="0"
                                Style="{StaticResource SectionHeaderButtonStyle}"
                                Click="SectionToggleButton_Click"
                                Tag="DataExchangeSectionContent|DataExchangeSectionChevron">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Style="{StaticResource SectionHeaderTitleStyle}"
                                           Text="数据导出"
                                           VerticalAlignment="Center"/>
                                <FontIcon Grid.Column="1"
                                          x:Name="DataExchangeSectionChevron"
                                          Glyph="&#xE70D;"
                                          Style="{StaticResource SectionChevronIconStyle}"/>
                            </Grid>
                        </Button>

                        <Grid Grid.Row="1"
                              x:Name="DataExchangeSectionContent"
                              Visibility="Collapsed"
                              Margin="0,6,0,0"
                              RowSpacing="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Button Grid.Column="0"
                                        Content="导出"
                                        Click="ExportJsonPackageButton_Click"
                                        HorizontalAlignment="Stretch"
                                        Padding="0,6"/>

                                <Button Grid.Column="1"
                                        Content="导入"
                                        Click="ImportDataPackageButton_Click"
                                        HorizontalAlignment="Stretch"
                                        Padding="0,6"/>
                            </Grid>

                            <TextBlock Grid.Row="1"
                                       x:Name="DataExchangeStatusText"
                                       Text="当前仅支持 JSON 导入导出；导入前会先自动备份当前数据。导入大约需要 15 秒，导入完成后剪切历史会自动刷新 UI。实际耗时取决于数据量，数据越多越久。"
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2"
                        Style="{StaticResource SettingsCardBorderStyle}"
                        >
                    <Grid RowSpacing="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" ColumnSpacing="6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       x:Name="UpdateBannerTitleText"
                                       Style="{StaticResource SettingsTitleStyle}"
                                       Text="版本检查"/>

                            <Button Grid.Column="1"
                                    x:Name="UpdateBannerToggleNotesButton"
                                    Width="28"
                                    Height="24"
                                    MinWidth="0"
                                    MinHeight="0"
                                    Padding="0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    ToolTipService.ToolTip="展开/收起更新说明"
                                    Visibility="Collapsed"
                                    Click="UpdateBannerToggleNotesButton_Click">
                                <FontIcon x:Name="UpdateBannerToggleGlyph" Glyph="&#xE70D;" FontSize="11"/>
                            </Button>
                        </Grid>

                        <TextBlock Grid.Row="1"
                                   x:Name="UpdateStatusText"
                                   Text="点击“检查更新”获取最新版本。"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                   VerticalAlignment="Center"/>

                        <Grid Grid.Row="2"
                              x:Name="UpdateBannerDetailsCard"
                              Visibility="Collapsed"
                              Margin="0,2,0,2">
                            <Grid ColumnSpacing="10"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="88"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Center"
                                            Spacing="6">
                                    <Image Source="ms-appx:///Assets/LiuYun.png"
                                           Width="70"
                                           Height="22"
                                           Stretch="Uniform"/>
                                    <TextBlock x:Name="UpdateBannerDetailsVersionText"
                                               Text="LiuYun 0.0.0"
                                               FontSize="11"
                                               TextAlignment="Center"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>

                                <TextBlock Grid.Column="1"
                                           x:Name="UpdateBannerDetailsNotesText"
                                           FontSize="11"
                                           TextWrapping="Wrap"
                                           TextAlignment="Left"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Grid>

                        <Button Grid.Row="3"
                                x:Name="CheckUpdateButton"
                                Content="检查更新"
                                Click="CheckUpdateAndInstallButton_Click"
                                HorizontalAlignment="Stretch"
                                Padding="0,6"/>

                        <Grid Grid.Row="4"
                              x:Name="UpdateBannerActionPanel"
                              Visibility="Collapsed"
                              ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Button x:Name="UpdateBannerInstallButton"
                                    Grid.Column="0"
                                    MinHeight="30"
                                    Padding="6,0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    HorizontalContentAlignment="Left"
                                    Click="UpdateBannerInstallButton_Click">
                                <TextBlock x:Name="UpdateBannerInstallText"
                                           Text="前往GitHub下载"
                                           FontSize="12"
                                           FontWeight="Normal"
                                           Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                            </Button>
                        </Grid>

                        <ProgressBar Grid.Row="4"
                                     x:Name="UpdateBannerProgressBarInline"
                                     Height="4"
                                     Minimum="0"
                                     Maximum="100"
                                     Visibility="Collapsed"/>
                    </Grid>
                </Border>

                <Border Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2"
                        Style="{StaticResource SettingsCompactCardBorderStyle}">
                    <Grid RowSpacing="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Button Grid.Row="0"
                                Style="{StaticResource SectionHeaderButtonStyle}"
                                Click="SectionToggleButton_Click"
                                Tag="CleanupSectionContent|CleanupSectionChevron">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Style="{StaticResource SectionHeaderTitleStyle}"
                                           Text="剪切板图片清理"
                                           VerticalAlignment="Center"/>
                                <FontIcon Grid.Column="1"
                                          x:Name="CleanupSectionChevron"
                                          Glyph="&#xE70D;"
                                          Style="{StaticResource SectionChevronIconStyle}"/>
                            </Grid>
                        </Button>

                        <Grid Grid.Row="1"
                              x:Name="CleanupSectionContent"
                              Visibility="Collapsed"
                              Margin="0,6,0,0"
                              RowSpacing="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="220"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="保留时长"
                                           VerticalAlignment="Center"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                                <ComboBox Grid.Column="1"
                                          x:Name="ClipboardImageCleanupComboBox"
                                          SelectionChanged="ClipboardImageCleanupComboBox_SelectionChanged">
                                    <ComboBoxItem Content="14天" Tag="Days14"/>
                                    <ComboBoxItem Content="1个月" Tag="Months1"/>
                                    <ComboBoxItem Content="2个月" Tag="Months2"/>
                                    <ComboBoxItem Content="3个月" Tag="Months3"/>
                                    <ComboBoxItem Content="6个月" Tag="Months6"/>
                                    <ComboBoxItem Content="1年" Tag="Year1"/>
                                    <ComboBoxItem Content="不清理" Tag="None"/>
                                </ComboBox>
                            </Grid>

                            <TextBlock Grid.Row="1"
                                       Text="仅清理剪切板图片目录（clipboard_images）。仅当数据库已无该图片索引且超过保留时长时，才会删除本地文件。选择“不清理”时，不会主动清理本地图片文件。"
                                       TextWrapping="Wrap"
                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                       FontSize="11"/>
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2"
                        Style="{StaticResource SettingsCardBorderStyle}">
                    <Grid RowSpacing="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Style="{StaticResource SettingsTitleStyle}"
                                   Text="应用信息"/>

                        <TextBlock Grid.Row="1"
                                   x:Name="CurrentVersionText"
                                   Text="当前版本：加载中..."
                                   FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                        <StackPanel Grid.Row="2"
                                    Orientation="Horizontal"
                                    Spacing="6">
                            <TextBlock Text="更新日志："
                                       VerticalAlignment="Center"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <HyperlinkButton Content="相关链接"
                                             NavigateUri="https://losst.net/archives/39/"
                                             Padding="0"
                                             VerticalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Row="3"
                                    Orientation="Horizontal"
                                    Spacing="6">
                            <TextBlock Text="开源地址："
                                       VerticalAlignment="Center"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <HyperlinkButton Content="GitHub链接"
                                             NavigateUri="https://github.com/xiuxiu733/LiuYun/"
                                             Padding="0"
                                             VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>


